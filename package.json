{
  "name": "spark-cli",
  "version": "1.0.0",
  "bin": {
    "spark": "src/index.tsx"
  },
  "dependencies": {
    "@opentui/core": "0.4.5",
    "@opentui/solid": "0.4.5",
    "imapflow": "^1.4.7",
    "mailparser": "^3.9.14",
    "solid-js": "1.9.12",
    "string-width": "^8.2.2",
    "yaml": "^2.9.0"
  },
  "scripts": {
    "start": "bun --preload @opentui/solid/preload src/index.tsx",
    "sync": "bun src/cli.ts sync",
    "typecheck": "tsc --noEmit",
    "build": "bun run scripts/build.ts",
    "install-bin": "bun run build && install -m 0755 dist/spark \"${PREFIX:-$HOME/.local/bin}/spark\" && echo installed to ${PREFIX:-$HOME/.local/bin}/spark"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "bun-types": "^1.3.14"
  }
}
