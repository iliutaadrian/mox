{
  "name": "spark-cli",
  "version": "1.0.0",
  "bin": {
    "spark": "src/index.tsx"
  },
  "dependencies": {
    "imapflow": "^1.4.7",
    "ink": "^7.1.0",
    "mailparser": "^3.9.14",
    "react": "^19.2.7",
    "react-devtools-core": "^7.0.1",
    "string-width": "^8.2.2",
    "yaml": "^2.9.0"
  },
  "scripts": {
    "start": "bun src/index.tsx",
    "sync": "bun src/cli.ts sync",
    "typecheck": "tsc --noEmit",
    "build": "bun build --compile --minify --outfile dist/spark src/index.tsx",
    "install-bin": "bun run build && install -m 0755 dist/spark \"${PREFIX:-$HOME/.local/bin}/spark\" && echo installed to ${PREFIX:-$HOME/.local/bin}/spark"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/react": "^19.2.17",
    "bun-types": "^1.3.14"
  }
}
