# dependencies
node_modules/

# local data + secrets (never commit)
*.db
config.yaml
.env
# …but the fictional demo config used to render README screenshots IS tracked
# (the demo DB itself is regenerated from docs/demo/seed.ts, so it stays ignored)
!docs/demo/config.yaml

# VHS scratch output (screenshots are committed; the recording gifs are not)
docs/tapes/.out*.gif

# task-observer skill log (not part of the app)
skill-observations/
fetch.log

# sqlite WAL sidecars
*.db-shm
*.db-wal

# local db backups
*.db.bak

# compiled standalone binary
/dist/
